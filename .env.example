# =============================================================================
# .env.example — IncluiAI
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o .env com chaves reais.
# =============================================================================

# ── IA ────────────────────────────────────────────────────────────────────────
VITE_GEMINI_API_KEY=sua_chave_google_gemini_aqui
VITE_OPENAI_API_KEY=sk-proj-...

# ── SUPABASE ──────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# URL base das Edge Functions (derivada da SUPABASE_URL)
VITE_SUPABASE_FUNCTIONS_URL=https://SEU_PROJECT_REF.supabase.co/functions/v1

# ── ASAAS (FRONTEND) ──────────────────────────────────────────────────────────
# Sandbox:  https://sandbox.asaas.com/api/v3
# Produção: https://api.asaas.com/v3
VITE_ASAAS_API_BASE=https://sandbox.asaas.com/api/v3

# Modo de chamada:
#   "direct" — chama Asaas direto do browser (apenas sandbox/dev)
#   "proxy"  — usa Edge Function asaas-proxy (obrigatório em produção)
VITE_ASAAS_MODE=direct

# API Key usada SOMENTE no modo "direct" (sandbox).
# Em produção, deixe vazio — a chave fica apenas nos secrets da Edge Function.
VITE_ASAAS_API_KEY=

# =============================================================================
# EDGE FUNCTIONS — Supabase Secrets
# Configure via CLI: supabase secrets set NOME=valor
# Ou no painel: Project → Edge Functions → Secrets
# =============================================================================
#
# ASAAS_API_KEY=sua_api_key_producao_asaas
#   Chave da API Asaas usada pelo asaas-proxy. Nunca exposta no frontend.
#
# ASAAS_WEBHOOK_SECRET=token_secreto_configurado_no_painel_asaas
#   Token de autenticação do webhook Asaas.
#   Configure em: Asaas → Configurações → Notificações → Webhook → Token
#   A Edge Function asaas-webhook verifica este token no header "asaas-access-token".
#
# SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co
#   URL do projeto (disponível automaticamente nas Edge Functions do Supabase)
#
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
#   Chave service_role para operações admin nas Edge Functions.
#   Disponível automaticamente nas Edge Functions do Supabase.
#   Nunca exposta no frontend.
#
# =============================================================================
# COMO CONFIGURAR OS SECRETS DA EDGE FUNCTION
# =============================================================================
#
# 1. Instale o Supabase CLI: npm install -g supabase
# 2. Faça login: supabase login
# 3. Link ao projeto: supabase link --project-ref SEU_PROJECT_REF
# 4. Configure os secrets:
#    supabase secrets set ASAAS_API_KEY=sua_chave_producao
#    supabase secrets set ASAAS_WEBHOOK_SECRET=seu_token_secreto
# 5. Verifique: supabase secrets list
#
# =============================================================================
