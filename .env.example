# =============================================================================
# .env.example — IncluiAI
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o .env com chaves reais.
# =============================================================================

# ── IA ────────────────────────────────────────────────────────────────────────
# Geração de TEXTO (obrigatório): google.com/generative-ai → API Keys
VITE_GEMINI_API_KEY=sua_chave_google_gemini_aqui

# Geração de IMAGENS via DALL-E 3 (obrigatório para atividades visuais):
# platform.openai.com → API Keys → Create new secret key
# Custo: ~US$ 0,04 por imagem (DALL-E 3 standard 1024x1024)
# Cada imagem consome 2 créditos do plano do usuário.
VITE_OPENAI_API_KEY=sk-proj-...

# ── SUPABASE ──────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# URL base das Edge Functions (derivada da SUPABASE_URL)
VITE_SUPABASE_FUNCTIONS_URL=https://SEU_PROJECT_REF.supabase.co/functions/v1

# ── KIWIFY — Links de checkout ────────────────────────────────────────────────
# Crie os produtos no painel Kiwify e cole os links abaixo.
# O webhook (Edge Function kiwify-webhook) atualiza plano + créditos após pagamento.
# Se estas variáveis não forem definidas, os links oficiais hardcoded em kiwifyService.ts serão usados.
VITE_KIWIFY_CHECKOUT_PRO=https://pay.kiwify.com.br/pyeMCOd
VITE_KIWIFY_CHECKOUT_PRO_ANNUAL=https://pay.kiwify.com.br/Ux6O9pR
VITE_KIWIFY_CHECKOUT_MASTER=https://pay.kiwify.com.br/yVg81A2
VITE_KIWIFY_CHECKOUT_MASTER_ANNUAL=https://pay.kiwify.com.br/Mqcsie2
VITE_KIWIFY_CHECKOUT_AI100=https://pay.kiwify.com.br/TZItLsS
VITE_KIWIFY_CHECKOUT_AI300=https://pay.kiwify.com.br/H1eyllS
VITE_KIWIFY_CHECKOUT_AI900=https://pay.kiwify.com.br/NqCj3Ks

# Portal do cliente Kiwify (opcional — link para o usuário gerenciar assinatura)
VITE_KIWIFY_CUSTOMER_PORTAL=https://kiwify.app/minha-conta

# =============================================================================
# EDGE FUNCTIONS — Supabase Secrets
# Configure via CLI: supabase secrets set NOME=valor
# Ou no painel: Project → Edge Functions → Secrets
# =============================================================================
#
# KIWIFY_WEBHOOK_SECRET=token_secreto_configurado_no_painel_kiwify
#   Token de autenticação do webhook Kiwify.
#   Configure em: Kiwify → Configurações → Webhooks → Secret
#   A Edge Function kiwify-webhook verifica este token.
#
# SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co
#   URL do projeto (disponível automaticamente nas Edge Functions do Supabase)
#
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
#   Chave service_role para operações admin nas Edge Functions.
#   Nunca exposta no frontend.
#
# =============================================================================
# COMO CONFIGURAR OS SECRETS DA EDGE FUNCTION
# =============================================================================
#
# 1. Instale o Supabase CLI: npm install -g supabase
# 2. Faça login: supabase login
# 3. Link ao projeto: supabase link --project-ref SEU_PROJECT_REF
# 4. Configure os secrets:
#    supabase secrets set KIWIFY_WEBHOOK_SECRET=seu_token_secreto
# 5. Verifique: supabase secrets list
#
# =============================================================================
